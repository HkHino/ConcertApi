      "name": "{{baseUrl}}/api/v1/oauth/token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));\r",
              "\r",
              "const json = pm.response.json();\r",
              "pm.environment.set(\"access_token\", json.access_token);\r",
              "if (json.refresh_token) pm.environment.set(\"refresh_token\", json.refresh_token);\r",
              "\r",
              "pm.test(\"access_token present\", () => pm.expect(json.access_token).to.be.a(\"string\"));\r",
              "pm.test(\"token_type is Bearer\", () => pm.expect(json.token_type).to.eql(\"Bearer\"));\r",
              "pm.test(\"expires_in present\", () => pm.expect(json.expires_in).to.be.a(\"number\"));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"grantType\": \"password\",\r\n  \"username\": \"admin@concert.local\",\r\n  \"password\": \"Password123!\"\r\n}",
